# Public site URL
NEXT_PUBLIC_SITE_URL=https://ak-ad.com

# Admin login
ADMIN_EMAIL=admin@ak-ad.com
ADMIN_PASSWORD=replace-with-a-strong-password
JWT_SECRET=replace-with-a-long-random-secret

# Email sending through Resend
RESEND_API_KEY=replace-with-your-resend-api-key
CONTACT_TO_EMAIL=contact@ak-ad.com
CONTACT_FROM_EMAIL=AK-AD media <onboarding@resend.dev>

# Optional: Vercel KV for persistent messages and digital test results
# Add the Vercel KV integration in Vercel, then copy these values.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=