# Public site URL
NEXT_PUBLIC_SITE_URL=https://ak-ad.com

# Optional FormSubmit hidden endpoint after first activation
# If empty, the form sends to https://formsubmit.co/contact@ak-ad.com
NEXT_PUBLIC_FORMSUBMIT_ENDPOINT=

# Admin login
ADMIN_EMAIL=admin@ak-ad.com
ADMIN_PASSWORD=replace-with-a-strong-password
JWT_SECRET=replace-with-a-long-random-secret

# Optional: Vercel KV for persistent admin CMS, digital test results and fallback internal messages
# Add the Vercel KV integration in Vercel, then copy these values.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=